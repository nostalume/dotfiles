{{/*
  chezmoi config should be independent of chezmoidata
*/}}

{{- $pubkey := "age18jcln2kqlqwpfjhtp9dnxsq2dnd604m5akuv5kfnqt3kxyvcdu5qvytrtu" -}}
{{- $shell      := "" -}}
{{- $editor     := "" -}}
{{- $pre        := "" -}}

{{/* Shell detection */}}
{{- if eq .chezmoi.os "windows" -}}
  {{- if lookPath "pwsh" -}}{{- $shell = "pwsh" -}}{{- else -}}{{- $shell = "powershell" -}}{{- end -}}
  {{- $pre = ".local/share/chezmoi/home/prepare/.prepare.ps1" -}}
{{- else -}}
  {{- if lookPath "fish" -}}{{- $shell = "fish" -}}{{- else -}}{{- $shell = "bash" -}}{{- end -}}
  {{- $pre = ".local/share/chezmoi/home/prepare/.prepare.sh" -}}
{{- end -}}

{{/* Editor detection: zed > nvim > platform fallback */}}
{{- if lookPath "zed" -}}
  {{- $editor = "zed" -}}
{{- else if lookPath "nvim" -}}
  {{- $editor = "nvim" -}}
{{- else if eq .chezmoi.os "windows" -}}
  {{- $editor = "code" -}}
{{- else -}}
  {{- $editor = "vi" -}}
{{- end -}}

encryption = "age"
[age]
  command = "rage"
  identity = "~/.config/chezmoi/key.txt"
  recipient = {{ $pubkey | quote }}

[data]
shell = {{ $shell | quote }}
editor = {{ $editor | quote }}
githubUserName = "nostalume"
gmail = "nostalucent@gmail.com"
olmail = "Nostalume@outlook.com"

[cd]
command = {{ $shell | quote }}

# **pwsh** is required
[interpreters.ps1]
command = "pwsh"
args = ["-NoLogo"]

[completion]
custom = true

[edit]
command = {{ $editor | quote }}

[merge]
  command = {{ $editor | quote }}
  args = [
      "-d",
      {{ printf "%q" "{{ .Destination }}" }},
      {{ printf "%q" "{{ .Source }}" }},
      {{ printf "%q" "{{ .Target }}" }},
  ]

[git]
autoAdd = true # Add changes to the source state after any change
autoCommit = false
autoPush = false

[hooks.read-source-state.pre]
command = {{ $shell | quote }}
args = {{ $pre | quote }}

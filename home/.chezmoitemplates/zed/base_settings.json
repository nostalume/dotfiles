{
	"helix_mode": true,
	"relative_line_numbers": "enabled",

	"colorize_brackets": true,
	"auto_indent_on_paste": true,
	"use_on_type_format": true,
	"soft_wrap": "editor_width",
	"hard_tabs": true,

	"autosave": {
		"after_delay": {
			"milliseconds": 500
		}
	},

	"ui_font_family": "Maple Mono",
	"buffer_font_family": "Maple Mono NF",
	"ui_font_size": 16,
	"buffer_font_size": 15,

	"terminal": {
		"font_family": "Maple Mono NF",
		"blinking": "on"
	},

	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "Catppuccin Mocha"
	},

	"file_types": {
		"json": ["*.json.tmpl", ".*.json.tmpl"],
		"yml": ["*.yml.tmpl", ".*.yml.tmpl"],
		"shellscript": ["*.sh.tmpl"],
		"gitignore": [
			"*chezmoiignore*",
			"*chezmoiremove*",
			"*gitignore*",
			"*rgignore*"
		],
		"bat": ["*.bat.tmpl"],
		"toml": ["*.toml.tmpl", ".*.toml.tmpl"],
		"powershell": ["*.ps1.tmpl"],
		"lua": ["*.lua.tmpl"],
		"yaml": ["*.ymal.tmpl", ".*.ymal.tmpl"]
	},

	"languages": {
		"Python": {
			"hard_tabs": false
		}
	},

	"lsp": {
		"tinymist": {
			"initialization_options": {
				"preview": {
					"background": {
						"enabled": true
					}
				}
			},
			"settings": {
				"exportPdf": "onType"
			}
		}
	}
}
